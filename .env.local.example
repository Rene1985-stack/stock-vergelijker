# Picqer API
PICQER_API_KEY=your_picqer_api_key
PICQER_BASE_URL=https://yourcompany.picqer.com

# Exact Online OAuth
EXACT_CLIENT_ID=your_exact_client_id
EXACT_CLIENT_SECRET=your_exact_client_secret
EXACT_REDIRECT_URI=http://localhost:3000/api/exact/callback

# Database (Neon / Vercel Postgres)
DATABASE_URL=postgres://user:password@host/database?sslmode=require
